/* 分析等待页样式 */
.waiting-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  padding-bottom: 200rpx;
  background: linear-gradient(180deg, #FFF5F0 0%, #FAFAFA 100%);
}

/* ========== 动画区域 ========== */
.animation-area {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 48rpx;
}

.pulse-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid #FF6B35;
  animation: pulse 2s ease-out infinite;
}

.pulse-ring.delay-1 {
  animation-delay: 0.5s;
}

.pulse-ring.delay-2 {
  animation-delay: 1s;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.center-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 80rpx;
  animation: iconPulse 1.5s ease-in-out infinite;
}

@keyframes iconPulse {
  0%, 100% {
    transform: translate(-50%, -50%) scale(1);
  }
  50% {
    transform: translate(-50%, -50%) scale(1.1);
  }
}

/* ========== 阶段信息 ========== */
.stage-info {
  text-align: center;
  margin-bottom: 48rpx;
}

.stage-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
  transition: all 300ms ease;
}

.stage-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.stage-step {
  font-size: 28rpx;
  font-weight: 500;
  color: #FF6B35;
}

/* ========== 进度条区域 ========== */
.progress-area {
  width: 100%;
  padding: 0 32rpx;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35 0%, #FFB347 100%);
  border-radius: 8rpx;
  transition: width 300ms ease;
  position: relative;
}

/* 进度条光泽动画 */
.progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.4),
    transparent
  );
  animation: shimmer 2s infinite;
}

@keyframes shimmer {
  100% {
    left: 100%;
  }
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-percent {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B35;
}

.remaining-time {
  font-size: 26rpx;
  color: #999999;
}

/* ========== 完成状态 ========== */
.completed-area {
  text-align: center;
}

.completed-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.completed-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.completed-desc {
  font-size: 28rpx;
  color: #666666;
}

/* ========== 错误状态 ========== */
.error-area {
  text-align: center;
  padding: 32rpx;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.error-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.error-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 32rpx;
}

.retry-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.profile-btn,
.service-btn {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  color: #FF6B35;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: 2rpx solid #FF6B35;
}

/* ========== 底部提示 ========== */
.bottom-hint {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 80rpx;
  display: flex;
  justify-content: center;
  padding-bottom: env(safe-area-inset-bottom);
}

.hint-card {
  background: rgba(255, 255, 255, 0.9);
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.hint-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #666666;
}