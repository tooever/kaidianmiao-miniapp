/* 表单页面样式 */
.form-page {
  min-height: 100vh;
  background: #FAFAFA;
  display: flex;
  flex-direction: column;
}

.steps-header {
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.form-content {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 180rpx;
}

.form-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #1A1A1A;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.form-label.required::before {
  content: '*';
  color: #EF4444;
  margin-right: 8rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #1A1A1A;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #999999;
}

/* 选择器 */
.form-picker {
  height: 96rpx;
  padding: 0 32rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  color: #1A1A1A;
}

.form-picker .placeholder {
  color: #999999;
}

.picker-arrow {
  color: #999999;
  font-size: 32rpx;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx 32rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #1A1A1A;
  box-sizing: border-box;
}

/* 多选框组 */
.checkbox-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.checkbox-item {
  padding: 16rpx 32rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.2s;
}

.checkbox-item.active {
  background: #FFF4EF;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
}

/* 单选框组 */
.radio-group {
  display: flex;
  gap: 48rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  color: #1A1A1A;
}

.radio-item radio {
  margin-right: 16rpx;
}

/* 底部按钮 */
.form-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

/* 主按钮 */
.btn-primary {
  flex: 1;
  height: 96rpx;
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
}

.btn-primary:active {
  background: #E55A2B;
}

.btn-primary[disabled] {
  background: #FFB088;
}

/* 次按钮 */
.btn-secondary {
  flex: 1;
  height: 96rpx;
  background: #FFFFFF;
  color: #FF6B35;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: 2rpx solid #FF6B35;
  display: flex;
  justify-content: center;
  align-items: center;
}

.btn-secondary:active {
  background: #FFF4EF;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}