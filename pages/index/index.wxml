<!--开店喵 - 首页-->
<view class="container">
  <!-- 顶部品牌区域 -->
  <view class="brand-section">
    <view class="brand-logo">
      <image class="logo-image" src="/assets/images/logo.png" mode="aspectFit"></image>
    </view>
    <view class="brand-slogan">{{slogan}}</view>
    <view class="brand-subtitle">智能选址评估，降低开店风险</view>
  </view>

  <!-- 主入口卡片 -->
  <view class="main-card">
    <view class="card-header">
      <view class="card-title">选址评估</view>
      <view class="card-badge">AI智能分析</view>
    </view>
    <view class="card-content">
      <view class="card-desc">
        通过大数据分析和AI算法，为您的店铺选址提供全方位的评估报告，帮助您做出更明智的决策。
      </view>
      <view class="card-price">
        <text class="price-symbol">¥</text>
        <text class="price-value">{{price}}</text>
        <text class="price-unit">/次</text>
      </view>
    </view>
    <view class="card-footer">
      <button class="start-btn" bindtap="onStartAssessment">
        开始评估
      </button>
    </view>
  </view>

  <!-- 信任背书区域 -->
  <view class="trust-section">
    <view class="trust-title">为什么选择开店喵</view>
    <view class="trust-list">
      <view class="trust-item" wx:for="{{features}}" wx:key="title">
        <view class="trust-icon">
          <image src="{{item.icon}}" mode="aspectFit"></image>
        </view>
        <view class="trust-info">
          <view class="trust-name">{{item.title}}</view>
          <view class="trust-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 历史记录入口 -->
  <view class="history-entry" bindtap="onViewHistory">
    <view class="history-icon">📋</view>
    <view class="history-text">查看我的评估报告</view>
    <view class="history-arrow">›</view>
  </view>

  <!-- 底部说明 -->
  <view class="footer-note">
    <text>开店喵 · 让每一次开店都更有把握</text>
  </view>
</view>