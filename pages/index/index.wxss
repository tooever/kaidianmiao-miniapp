/**
 * 开店喵 - 首页样式
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F0 0%, #FAFAFA 30%);
  padding-bottom: 120rpx;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.brand-logo {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.3);
}

.logo-image {
  width: 100rpx;
  height: 100rpx;
}

.brand-slogan {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.brand-subtitle {
  font-size: 26rpx;
  color: #666666;
}

/* 主入口卡片 */
.main-card {
  margin: 20rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F5A 50%, #FFB347 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 53, 0.25);
  position: relative;
  overflow: hidden;
}

.main-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.card-badge {
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.25);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.card-content {
  margin-bottom: 32rpx;
}

.card-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.card-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.price-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.price-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: center;
}

.start-btn {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  color: #FF6B35;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.start-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 信任背书区域 */
.trust-section {
  padding: 40rpx 32rpx;
}

.trust-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  text-align: center;
  margin-bottom: 32rpx;
}

.trust-list {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.trust-item {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.trust-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFF5F0 0%, #FFE8DD 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.trust-icon image {
  width: 48rpx;
  height: 48rpx;
}

.trust-info {
  width: 100%;
}

.trust-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.trust-desc {
  font-size: 22rpx;
  color: #999999;
}

/* 历史记录入口 */
.history-entry {
  display: flex;
  align-items: center;
  margin: 20rpx 32rpx;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.history-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.history-text {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
}

.history-arrow {
  font-size: 36rpx;
  color: #999999;
}

/* 底部说明 */
.footer-note {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #999999;
}