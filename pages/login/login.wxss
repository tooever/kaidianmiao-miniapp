.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: linear-gradient(180deg, #FFF5F0 0%, #FAFAFA 100%);
}

.login-header {
  text-align: center;
  margin-bottom: 120rpx;
}

.login-logo {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #666666;
}

.login-btn {
  width: 600rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.login-tips {
  margin-top: 48rpx;
  font-size: 24rpx;
  color: #999999;
}

.link {
  color: #FF6B35;
}