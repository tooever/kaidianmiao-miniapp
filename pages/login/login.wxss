/* 登录页面样式 */
.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #FFF4EF 0%, #FFFFFF 50%);
  padding: 0 32rpx;
}

.login-header {
  text-align: center;
  padding-top: 160rpx;
  padding-bottom: 80rpx;
}

.login-logo {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #666666;
}

.login-content {
  flex: 1;
  padding: 0 32rpx;
}

.login-features {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.feature-item:not(:last-child) {
  border-bottom: 1rpx solid #EEEEEE;
}

.feature-icon {
  color: #10B981;
  font-size: 32rpx;
  margin-right: 24rpx;
  width: 40rpx;
}

.feature-text {
  font-size: 32rpx;
  color: #1A1A1A;
}

.login-footer {
  padding: 48rpx 0;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: #FF6B35;
  border-radius: 48rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
}

.login-btn:active {
  background: #E55A2B;
  transform: scale(0.98);
}

.login-btn[disabled] {
  background: #FFB088;
  color: #FFFFFF;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.login-tips {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 32rpx;
}

.link {
  color: #FF6B35;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}