/* 支付审核中页样式 */
.pending-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F0 0%, #FAFAFA 30%);
  padding: 80rpx 24rpx 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 状态图标区域 */
.status-icon-area {
  margin-bottom: 48rpx;
}

.status-icon-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 脉冲动画 */
.pulse-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid #FF6B35;
  animation: pulse 2s ease-out infinite;
}

.pulse-ring.delay-1 {
  animation-delay: 0.5s;
}

.pulse-ring.delay-2 {
  animation-delay: 1s;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.status-icon {
  font-size: 80rpx;
  z-index: 1;
}

/* 状态文本 */
.status-content {
  text-align: center;
  margin-bottom: 48rpx;
}

.status-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 28rpx;
  color: #666666;
}

/* 订单信息卡片 */
.order-info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  width: 100%;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-row:not(:last-child) {
  border-bottom: 1rpx solid #F0F0F0;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
}

.info-value {
  font-size: 28rpx;
  color: #1A1A1A;
}

.info-value.highlight {
  color: #FF6B35;
  font-weight: 500;
}

/* 提示信息 */
.tips-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  width: 100%;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 20rpx;
}

.tips-list {
  padding-left: 8rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tips-item:last-child {
  margin-bottom: 0;
}

.tips-bullet {
  font-size: 26rpx;
  color: #FF6B35;
  margin-right: 12rpx;
}

.tips-item text:last-child {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

/* 底部操作 */
.pending-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.contact-btn {
  flex: 1;
  height: 88rpx;
  background: #F5F5F5;
  color: #666666;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contact-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.home-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}