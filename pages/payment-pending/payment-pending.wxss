.pending-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: #FAFAFA;
}

.pending-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.pending-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.pending-desc {
  font-size: 28rpx;
  color: #FF6B35;
  margin-bottom: 60rpx;
}

.pending-tips {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  width: 100%;
}

.tip-item {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.tip-item:first-child {
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 24rpx;
}