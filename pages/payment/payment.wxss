.payment-container {
  min-height: 100vh;
  background: #FAFAFA;
  padding-bottom: 200rpx;
}

.payment-header {
  padding: 40rpx 32rpx 24rpx;
}

.payment-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.package-list {
  padding: 0 24rpx;
}

.package-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid transparent;
  position: relative;
}

.package-item.active {
  border-color: #FF6B35;
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.05) 0%, rgba(255, 179, 71, 0.05) 100%);
}

.package-main {
  flex: 1;
}

.package-count {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.package-label {
  font-size: 24rpx;
  color: #999999;
}

.package-discount {
  display: inline-block;
  font-size: 20rpx;
  color: #FF6B35;
  background: rgba(255, 107, 53, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
}

.package-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 500;
}

.price-value {
  font-size: 44rpx;
  color: #FF6B35;
  font-weight: 700;
}

.package-check {
  width: 48rpx;
  height: 48rpx;
  background: #FF6B35;
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.payment-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.payment-total {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.total-label {
  font-size: 28rpx;
  color: #666666;
}

.total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B35;
}

.pay-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}