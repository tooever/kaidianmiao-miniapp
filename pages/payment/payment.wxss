/* 支付确认页样式 */
.payment-container {
  min-height: 100vh;
  background: #FAFAFA;
  padding: 24rpx 24rpx 200rpx;
}

/* 订单信息卡片 */
.order-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.order-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.order-product {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #999999;
}

.product-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 500;
}

.price-value {
  font-size: 44rpx;
  color: #FF6B35;
  font-weight: 700;
}

/* 二维码区域 */
.qrcode-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.qrcode-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.qrcode-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.qrcode-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.qrcode-image {
  width: 320rpx;
  height: 320rpx;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  background: #F5F5F5;
}

.qrcode-hint {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666666;
  text-align: center;
}

.qrcode-amount {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.amount-label {
  font-size: 28rpx;
  color: #666666;
}

.amount-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B35;
}

/* 安全保障说明 */
.security-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
}

.security-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.security-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.security-title text:last-child {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.security-list {
  padding-left: 8rpx;
}

.security-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.security-check {
  color: #10B981;
  font-size: 24rpx;
  margin-right: 12rpx;
  font-weight: 600;
}

.security-item text:last-child {
  font-size: 26rpx;
  color: #666666;
}

/* 底部操作区 */
.payment-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.service-entry {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F5F5F5;
  border-radius: 40rpx;
  margin-right: 20rpx;
}

.service-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.service-text {
  font-size: 26rpx;
  color: #666666;
}

.confirm-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.confirm-btn.disabled {
  opacity: 0.6;
}

/* 加载中 */
.loading-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}