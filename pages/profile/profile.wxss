.profile-container {
  min-height: 100vh;
  background: #FAFAFA;
}

/* 用户区域 */
.user-section {
  display: flex;
  align-items: center;
  padding: 60rpx 32rpx 48rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #FFFFFF;
  margin-right: 24rpx;
}

.default-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-hint {
  font-size: 26rpx;
  color: #FFFFFF;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  display: inline-block;
}

/* 统计区域 */
.stats-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: -24rpx 32rpx 24rpx;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B35;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #EEEEEE;
}

/* 菜单区域 */
.menu-section {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #1A1A1A;
}

.menu-count {
  font-size: 24rpx;
  color: #FFFFFF;
  background: #FF6B35;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
  min-width: 40rpx;
  text-align: center;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

/* 退出登录 */
.logout-section {
  margin: 60rpx 32rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  color: #EF4444;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #EF4444;
}

.logout-btn::after {
  border: none;
}

/* 底部信息 */
.footer-section {
  text-align: center;
  padding: 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #CCCCCC;
  margin-bottom: 8rpx;
}