.list-container {
  min-height: 100vh;
  background: #FAFAFA;
  padding: 24rpx;
}

.report-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.shop-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.score-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.score-excellent {
  background: rgba(16, 185, 129, 0.1);
  color: #10B981;
}

.score-good {
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
}

.score-medium {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.card-body {
  padding: 16rpx 0;
  border-top: 1rpx solid #EEEEEE;
  border-bottom: 1rpx solid #EEEEEE;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-item {
  font-size: 26rpx;
}

.info-label {
  color: #999999;
}

.info-value {
  color: #666666;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.create-time {
  font-size: 24rpx;
  color: #999999;
}

.view-btn {
  font-size: 26rpx;
  color: #FF6B35;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.empty-btn {
  width: 240rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}