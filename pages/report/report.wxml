<view class="report-container" wx:if="{{!isLoading && report}}">
  <!-- 报告头部 -->
  <view class="report-header">
    <view class="score-circle">
      <view class="score-value">{{report.score}}</view>
      <view class="score-label">综合评分</view>
    </view>
    <view class="level-badge level-{{report.level === '优秀' ? 'excellent' : report.level === '良好' ? 'good' : 'medium'}}">
      {{report.level}}
    </view>
  </view>
  
  <!-- 店铺信息 -->
  <view class="info-section">
    <view class="info-item">
      <view class="info-label">店铺名称</view>
      <view class="info-value">{{report.shopName}}</view>
    </view>
    <view class="info-item">
      <view class="info-label">店铺类型</view>
      <view class="info-value">{{report.shopType}}</view>
    </view>
    <view class="info-item">
      <view class="info-label">店铺地址</view>
      <view class="info-value">{{report.address}}</view>
    </view>
  </view>
  
  <!-- 维度评分 -->
  <view class="dimensions-section">
    <view class="section-title">维度分析</view>
    <view class="dimension-list">
      <view class="dimension-item" wx:for="{{report.dimensions}}" wx:key="name">
        <view class="dimension-header">
          <view class="dimension-name">{{item.name}}</view>
          <view class="dimension-score">{{item.score}}分</view>
        </view>
        <view class="dimension-bar">
          <view class="dimension-fill status-{{item.status}}" style="width: {{item.score}}%"></view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 建议 -->
  <view class="suggestions-section">
    <view class="section-title">决策建议</view>
    <view class="suggestion-list">
      <view class="suggestion-item" wx:for="{{report.suggestions}}" wx:key="index">
        <view class="suggestion-bullet">•</view>
        <view class="suggestion-text">{{item}}</view>
      </view>
    </view>
  </view>
  
  <!-- 底部操作 -->
  <view class="report-footer safe-area-bottom">
    <button class="action-btn secondary" bindtap="onShare">分享报告</button>
    <button class="action-btn primary">保存到相册</button>
  </view>
</view>

<view class="loading-container" wx:if="{{isLoading}}">
  <view class="loading-text">加载中...</view>
</view>