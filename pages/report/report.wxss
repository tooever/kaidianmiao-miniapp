.report-container {
  min-height: 100vh;
  background: #FAFAFA;
  padding-bottom: 160rpx;
}

/* 报告头部 */
.report-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
  background: linear-gradient(180deg, #FFF5F0 0%, #FAFAFA 100%);
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 53, 0.3);
}

.score-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.level-badge {
  font-size: 28rpx;
  font-weight: 600;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
}

.level-excellent {
  background: rgba(16, 185, 129, 0.1);
  color: #10B981;
}

.level-good {
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
}

.level-medium {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

/* 信息区域 */
.info-section {
  background: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
  width: 160rpx;
}

.info-value {
  font-size: 28rpx;
  color: #1A1A1A;
  text-align: right;
  flex: 1;
}

/* 维度评分 */
.dimensions-section {
  background: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 24rpx;
}

.dimension-item {
  margin-bottom: 24rpx;
}

.dimension-item:last-child {
  margin-bottom: 0;
}

.dimension-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dimension-name {
  font-size: 26rpx;
  color: #666666;
}

.dimension-score {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.dimension-bar {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.dimension-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.status-good {
  background: linear-gradient(90deg, #10B981 0%, #34D399 100%);
}

.status-medium {
  background: linear-gradient(90deg, #F59E0B 0%, #FBBF24 100%);
}

.status-poor {
  background: linear-gradient(90deg, #EF4444 0%, #F87171 100%);
}

/* 建议 */
.suggestions-section {
  background: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
}

.suggestion-item {
  display: flex;
  margin-bottom: 20rpx;
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

.suggestion-bullet {
  color: #FF6B35;
  font-size: 28rpx;
  margin-right: 12rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  flex: 1;
}

/* 底部操作 */
.report-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  color: #FFFFFF;
}

.action-btn.secondary {
  background: #FFFFFF;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
}

.loading-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}