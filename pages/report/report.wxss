/**
 * 开店喵 - 评估报告详情页样式
 */

.report-page {
  min-height: 100vh;
  background: #FAFAFA;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载状态 */
.loading-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #EEEEEE;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999999;
}

/* 错误状态 */
.error-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: #FAFAFA;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 32rpx;
  text-align: center;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 32rpx;
  border: none;
}

/* 评分展示区 */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 48rpx;
  background: linear-gradient(180deg, #FF6B35 0%, #FF8F5E 100%);
}

.score-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.score-number {
  font-size: 80rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* 风险等级标签 */
.risk-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-top: 20rpx;
}

.risk-tag--low {
  background: rgba(16, 185, 129, 0.2);
  color: #FFFFFF;
}

.risk-tag--medium {
  background: rgba(245, 158, 11, 0.2);
  color: #FFFFFF;
}

.risk-tag--high {
  background: rgba(239, 68, 68, 0.2);
  color: #FFFFFF;
}

.score-summary {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  line-height: 1.6;
  max-width: 600rpx;
}

/* 四维度评分卡片 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  padding: 32rpx 32rpx 20rpx;
}

.dimensions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 32rpx;
}

.dimension-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.dimension-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dimension-name {
  font-size: 26rpx;
  color: #666666;
}

.dimension-score {
  font-size: 28rpx;
  font-weight: 600;
}

.dimension-progress {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.dimension-progress-bar {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.8s ease;
}

.dimension-analysis {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 核心建议列表 */
.suggestions-container {
  padding: 0 32rpx;
}

.suggestion-card {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.suggestion-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.suggestion-content {
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.6;
  flex: 1;
}

/* 风险清单 */
.risk-section {
  margin: 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.risk-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  cursor: pointer;
}

.risk-header-left {
  display: flex;
  align-items: center;
}

.risk-header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.risk-count {
  font-size: 24rpx;
  color: #999999;
  margin-left: 8rpx;
}

.risk-arrow {
  font-size: 20rpx;
  color: #999999;
  transition: transform 0.3s;
}

.risk-arrow--expanded {
  transform: rotate(180deg);
}

.risk-list {
  border-top: 1rpx solid #F5F5F5;
}

.risk-item {
  display: flex;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.risk-item:last-child {
  border-bottom: none;
}

.risk-bar {
  width: 6rpx;
  border-radius: 3rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.risk-bar--high {
  background: #EF4444;
}

.risk-bar--medium {
  background: #F59E0B;
}

.risk-bar--low {
  background: #10B981;
}

.risk-detail {
  flex: 1;
}

.risk-level-text {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
}

.risk-level-high {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}

.risk-level-medium {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.risk-level-low {
  background: rgba(16, 185, 129, 0.1);
  color: #10B981;
}

.risk-content {
  display: block;
  font-size: 26rpx;
  color: #1A1A1A;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.risk-mitigation {
  display: block;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

/* 底部占位 */
.bottom-placeholder {
  height: 160rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #EEEEEE;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.btn-share {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  margin-right: 16rpx;
  background: #FFF3ED;
  color: #FF6B35;
  border: none;
}

.btn-share::after {
  border: none;
}

.btn-reassess {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  color: #FFFFFF;
  border: none;
}

.btn-reassess::after {
  border: none;
}